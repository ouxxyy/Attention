{
  "name": "AttentionBudget - 注意力预算管理器",
  "version": "1.0.0",
  "description": "像会计记账一样追踪每一分钟注意力，用柔性引导而非强制屏蔽帮助你专注",
  "manifest_version": 3,
  "minimum_chrome_version": "88",
  "icons": {
    "16": "src/icons/icon16.svg",
    "48": "src/icons/icon48.svg",
    "128": "src/icons/icon128.svg"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon16.svg",
      "48": "src/icons/icon48.svg",
      "128": "src/icons/icon128.svg"
    },
    "default_title": "AttentionBudget"
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content.ts"],
      "css": ["src/content/content.css"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["tabs", "storage", "alarms", "notifications", "idle"],
  "host_permissions": ["<all_urls>"],
  "options_page": "src/options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["src/dashboard/dashboard.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
