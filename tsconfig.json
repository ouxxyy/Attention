{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "outDir": "./dist",
    "rootDir": ".",
    "resolveJsonModule": true,
    "declaration": true
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "client/src/**/*.ts",
    "client/src/**/*.tsx",
    "vite.config.ts"
  ]
}
