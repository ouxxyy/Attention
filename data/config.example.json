{
  "host": "localhost",
  "activityWatchBaseUrl": "http://localhost:5600/api/0",
  "thresholds": {
    "flowMinMinutes": 25,
    "shortSwitchMaxMinutes": 2,
    "frequentSwitchWindowMinutes": 15,
    "frequentSwitchCount": 6,
    "afkGraceMinutes": 3
  },
  "mainTaskKeywords": [
    {
      "label": "Writing",
      "patterns": [
        "writing",
        "docs",
        "document"
      ],
      "match": "substring",
      "priority": 100
    },
    {
      "label": "Coding",
      "patterns": [
        "code",
        "IDE",
        "VS Code",
        "cursor",
        "Codex",
        "opencode",
        "GitHub"
      ],
      "match": "substring",
      "priority": 90
    },
    {
      "label": "Reading",
      "patterns": [
        "reading",
        "article",
        "book"
      ],
      "match": "substring",
      "priority": 80
    }
  ],
  "sharedKeywords": [],
  "notifications": {
    "enabled": false,
    "cooldownMinutes": 15
  },
  "internalUrlProtocols": [
    "chrome:",
    "about:",
    "edge:",
    "brave:",
    "devtools:"
  ]
}
